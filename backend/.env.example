DB_HOST=localhost
DB_NAME=supplier_eval
DB_USER=root
DB_PASS=secret
JWT_SECRET=your-super-secret-key-here-min-32-chars
JWT_EXPIRY=28800
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USER=your_mailtrap_user
MAIL_PASS=your_mailtrap_pass
MAIL_FROM=noreply@yourcompany.com
ADMIN_EMAIL=admin@yourcompany.com
UPLOAD_PATH=/var/uploads/supplier-eval
APP_ENV=production
FRONTEND_URL=https://yourapp.vercel.app

# ProcureAI (Groq)
# Create an API key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Tender images
# Pexels API key: https://www.pexels.com/api/new/
PEXELS_API_KEY=your-pexels-api-key
# Pixabay API key: https://pixabay.com/api/docs/
PIXABAY_API_KEY=your-pixabay-api-key

# Brevo (Sendinblue) transactional email
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=noreply@procurease.com
BREVO_SENDER_NAME=ProcurEase Notifications
