# Railway MySQL Database Variables
# Copy these from your Railway MySQL service Variables tab

MYSQLHOST=containers-us-west-123.railway.app
MYSQLPORT=XXXX
MYSQLDATABASE=railway
MYSQLUSER=root
MYSQLPASSWORD=your_password_here

# Optional JWT secret (generate with: openssl rand -hex 32)
JWT_SECRET=your_jwt_secret_here

# Email (if using)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# App settings
APP_DEBUG=true

